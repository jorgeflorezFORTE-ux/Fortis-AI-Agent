# ══════════════════════════════════════════════════════════════
# JP LEGACY FINANCE — Variables de Entorno
# ══════════════════════════════════════════════════════════════
# Copia este archivo como .env.local y llena los valores

# ── URL de tu app ──────────────────────────────────────────
APP_URL=http://localhost:3000

# ── Anthropic (Claude AI) ─────────────────────────────────
# Obtén tu key en: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# ── QuickBooks OAuth ──────────────────────────────────────
# Crea tu app gratis en: https://developer.intuit.com
# 1. "Create an app" → "QuickBooks Online and Payments"
# 2. Redirect URI: http://localhost:3000/api/qb/callback
QB_CLIENT_ID=
QB_CLIENT_SECRET=
QB_REDIRECT_URI=http://localhost:3000/api/qb/callback
QB_ENVIRONMENT=sandbox

# ── QuickBooks Realm IDs (Company IDs) ────────────────────
# Estos se llenan automáticamente al conectar cada empresa.
# También puedes encontrarlos en QuickBooks > Configuración > Cuenta
QB_REALM_REAL_LEGACY=
QB_REALM_JP_MEDIA=
QB_REALM_PAOLA_PA=
QB_REALM_VAU_NUTRITION=
QB_REALM_REBORN=
QB_REALM_JORGE_LLC=
