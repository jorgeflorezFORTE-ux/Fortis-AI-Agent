# ─── Anthropic ───────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── QuickBooks OAuth ─────────────────────────────────────────
# Crea tu app en https://developer.intuit.com
# Tipo: Web App | Scopes: Accounting
QB_CLIENT_ID=
QB_CLIENT_SECRET=
QB_ENVIRONMENT=production
# Para desarrollo local: http://localhost:3000/api/qb/callback
# Para Vercel: https://TU-APP.vercel.app/api/qb/callback
QB_REDIRECT_URI=http://localhost:3000/api/qb/callback

# ─── QuickBooks Realm IDs ─────────────────────────────────────
# Encuentra cada Realm ID en QuickBooks → Configuración → Sobre QuickBooks
QB_REALM_REAL_LEGACY=
QB_REALM_JP_MEDIA=
QB_REALM_VAU_NUTRITION=
QB_REALM_PAOLA_PA=
QB_REALM_REBORN_HOUSES=
QB_REALM_JP_HOMES=
QB_REALM_JORGE_LLC=

# ─── App ──────────────────────────────────────────────────────
NEXTAUTH_SECRET=genera-un-string-aleatorio-aqui
NEXT_PUBLIC_APP_URL=http://localhost:3000
